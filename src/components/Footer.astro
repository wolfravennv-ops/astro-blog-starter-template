---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="sigil-line"></div>

		<p class="title">Elf.Darkbot.cc</p>
		<p class="text">
			Occult archive. Desert-forged signal. Built under darker skies.
		</p>

		<div class="links">
			<a href="/">Sanctum</a>
			<a href="https://darkbot.cc">Darkbot</a>
			<a href="https://rust.darkbot.cc">Rust Realm</a>
		</div>

		<p class="copy">
			&copy; {today.getFullYear()} Wolf Raven. All rights reserved.
		</p>
	</div>
</footer>

<style>
	footer {
		margin-top: 3rem;
		padding: 2.5rem 1rem 3.5rem;
		background:
			linear-gradient(180deg, rgba(10, 10, 14, 0.4), rgba(5, 5, 8, 0.92));
		border-top: 1px solid rgba(188, 166, 235, 0.12);
	}

	.footer-inner {
		max-width: 1180px;
		margin: 0 auto;
		text-align: center;
		color: #a79eb9;
	}

	.sigil-line {
		width: min(220px, 70%);
		height: 1px;
		margin: 0 auto 1.3rem;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(140, 103, 216, 0.8),
			transparent
		);
		box-shadow: 0 0 12px rgba(140, 103, 216, 0.28);
	}

	.title {
		margin: 0;
		font-size: 1rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #ece7f6;
	}

	.text {
		max-width: 620px;
		margin: 0.8rem auto 0;
		line-height: 1.7;
		font-size: 0.96rem;
		color: #9e94b5;
	}

	.links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 1.25rem;
	}

	.links a {
		padding: 0.7rem 0.95rem;
		border-radius: 10px;
		border: 1px solid rgba(188, 166, 235, 0.12);
		background: rgba(255, 255, 255, 0.02);
		color: #d7c6ff;
		text-decoration: none;
		transition: 0.2s ease;
	}

	.links a:hover {
		transform: translateY(-2px);
		background: rgba(140, 103, 216, 0.08);
		border-color: rgba(188, 166, 235, 0.2);
		color: #fff;
	}

	.copy {
		margin-top: 1.4rem;
		font-size: 0.88rem;
		letter-spacing: 0.04em;
		color: #7f768f;
	}

	@media (max-width: 640px) {
		footer {
			padding: 2rem 1rem 3rem;
		}

		.links {
			gap: 0.55rem;
		}

		.links a {
			padding: 0.65rem 0.85rem;
		}
	}
</style>
